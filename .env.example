# ── Supabase (shared with the orenew desktop app) ───────────────────────────
# URL + anon key are the SAME project the desktop app uses. The anon key is
# public and safe to ship to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# Server-only. Bypasses RLS — used ONLY inside webhook/admin route handlers.
# NEVER expose to the client / never prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# ── Lemon Squeezy (merchant-of-record) ──────────────────────────────────────
# API key with read/write for checkouts + subscriptions (server-only).
LEMONSQUEEZY_API_KEY=<ls-api-key>
# Store id (numeric) the products live in.
LEMONSQUEEZY_STORE_ID=<store-id>
# Webhook signing secret configured in the LS dashboard.
LEMONSQUEEZY_WEBHOOK_SECRET=<ls-webhook-secret>

# One variant id per paid tier × period (4 total). Server-only.
LEMONSQUEEZY_VARIANT_PRO_MONTHLY=<variant-id>
LEMONSQUEEZY_VARIANT_PRO_YEARLY=<variant-id>
LEMONSQUEEZY_VARIANT_STUDIO_MONTHLY=<variant-id>
LEMONSQUEEZY_VARIANT_STUDIO_YEARLY=<variant-id>

# ── Site ────────────────────────────────────────────────────────────────────
# Public base URL, used for checkout redirect + OG tags.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# GitHub repo (owner/name) whose Releases back the Download page.
NEXT_PUBLIC_GITHUB_REPO=EladBarkay/orenew
